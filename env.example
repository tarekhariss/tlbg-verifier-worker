# =============================================================================
# TLBG Verifier Worker — environment configuration
# Copy to .env (local) or set as Railway service variables.
# =============================================================================

# --- REQUIRED: platform connection ---
# Full URL to the verification-worker-api edge function on the TLBG platform.
SUPABASE_WORKER_API_URL=https://YOUR-PROJECT.supabase.co/functions/v1/verification-worker-api

# Shared secret. Must match the VERIFICATION_WORKER_SECRET set on the TLBG
# platform side. Sent on every request as the `x-worker-secret` header.
VERIFICATION_WORKER_SECRET=replace-me

# --- Worker identity ---
WORKER_ID=worker-eu-1
WORKER_VERSION=1.0.0
WORKER_HOST=railway-eu-west

# --- SMTP verifier engine ---
# When deploying on Railway: run AfterShip email-verifier as a separate
# Railway service and point VERIFIER_URL at its private networking URL.
# When using docker-compose locally: leave as http://email-verifier:8080.
VERIFIER_URL=http://email-verifier:8080
VERIFIER_ENGINE=aftership-email-verifier
VERIFIER_VERSION=1.7.2

# --- Tuning ---
CLAIM_BATCH_SIZE=50
CLAIM_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=60000
MAX_CONCURRENCY=10
PER_DOMAIN_DELAY_MS=5000
MAX_RETRIES=3
